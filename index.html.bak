<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>AS 有机反应跳棋 - 深度挑战版</title>
    <style>
        body { font-family: 'PingFang SC', sans-serif; display: flex; flex-direction: column; align-items: center; background: #f0f2f5; margin: 0; padding: 20px; }
        #game-layout { display: flex; gap: 30px; margin-top: 10px; }
        #board-container { background: #fff; padding: 20px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: 2px solid #d1d8e0; }
        .row { display: flex; justify-content: center; margin: -6px 0; }
        .slot { width: 40px; height: 40px; border-radius: 50%; background: #f1f2f6; margin: 4px; cursor: pointer; display: flex; justify-content: center; align-items: center; transition: 0.2s; border: 2px solid transparent; }
        .slot:hover { background: #dfe4ea; }
        .slot.selected { border-color: #2f3542; background: #ced6e0; box-shadow: 0 0 10px rgba(0,0,0,0.2); z-index: 10; }
        .slot.jump-debug { outline: 3px solid orange; box-shadow: 0 0 10px orange; }
        .slot.walk-debug { outline: 2px solid limegreen; }
        .slot.pending-target { outline: 2px solid #007bff; box-shadow: 0 0 8px rgba(0, 123, 255, 0.45); z-index: 5; }
        .piece { width: 32px; height: 32px; border-radius: 50%; box-shadow: 0 3px 6px rgba(0,0,0,0.2); pointer-events: none; }
        .p1 { background: radial-gradient(circle at 30% 30%, #ff4757, #ff6b81); }
        .p2 { background: radial-gradient(circle at 30% 30%, #2e86de, #54a0ff); }
        #info-panel { width: 380px; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); display: flex; flex-direction: column; }
        #info-panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 2px;
        }
        #info-panel-header #turn-display { flex: 1; min-width: 0; }
        #question-box { border-radius: 8px; background: #f8f9fa; padding: 15px; margin: 15px 0; border-left: 5px solid #007bff; min-height: 140px; }
        #question-timer-wrap { margin-bottom: 12px; }
        #question-timer-wrap.hidden { display: none; }
        #question-timer-text { font-size: 15px; font-weight: bold; text-align: center; margin-bottom: 6px; color: #333; }
        #question-timer-bar-outer {
            height: 10px;
            border-radius: 6px;
            background: #e0e0e0;
            overflow: hidden;
        }
        #question-timer-bar {
            height: 100%;
            width: 100%;
            border-radius: 6px;
            transition: width 0.05s linear, background 0.05s linear;
            background: hsl(120, 85%, 50%);
        }

            border-radius: 10px;
        }
        .option-btn { width: 100%; padding: 12px; margin: 6px 0; border: 1px solid #ddd; border-radius: 6px; background: #fff; cursor: pointer; text-align: left; transition: 0.2s; font-size: 13.5px; }
        .option-btn:hover:not(:disabled) { background: #eef2f7; border-color: #007bff; }
        .status-msg { font-weight: bold; text-align: center; padding: 10px; border-radius: 6px; margin-top: 10px; display: none; }
        .correct { background: #d4edda; color: #155724; }
        .incorrect { background: #f8d7da; color: #721c24; }
        .controls { margin-top: auto; padding-top: 20px; }
        .btn-action { width: 100%; padding: 14px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 15px; }
        #end-turn-btn { background: #2f3542; color: white; display: none; margin-bottom: 20px; }
        #restart-btn { background: none; border: 1px solid #d1d8e0; color: #999; font-size: 12px; margin-top: 60px; }
        #restart-btn:hover { color: #ff4757; border-color: #ff4757; background: #fff5f5; }
        #change-names-btn {
            position: fixed;
            right: 15px;
            top: 15px;
            z-index: 1000;
            padding: 8px 14px;
            border-radius: 8px;
            border: 1px solid #d1d8e0;
            background: #fff;
            color: #333;
            font-size: 13px;
            font-family: inherit;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,0.12);
            transition: background 0.2s, transform 0.2s, box-shadow 0.2s, border-color 0.2s;
        }
        #change-names-btn:hover {
            background: #eef2f7;
            transform: scale(1.05);
            box-shadow: 0 3px 12px rgba(0,0,0,0.15);
        }
        #name-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: center; z-index: 2000; }
        #name-modal .modal-box { background: #fff; padding: 28px 32px; border-radius: 14px; box-shadow: 0 12px 40px rgba(0,0,0,0.18); min-width: 320px; max-width: 90vw; }
        #name-modal .modal-box h2 { margin: 0 0 18px; font-size: 1.25rem; text-align: center; }
        #name-modal .modal-field { margin-bottom: 14px; }
        #name-modal .modal-field label { display: block; font-size: 13px; color: #555; margin-bottom: 6px; }
        #name-modal .modal-field input { width: 100%; box-sizing: border-box; padding: 10px 12px; border: 1px solid #d1d8e0; border-radius: 8px; font-size: 15px; font-family: inherit; }
        #name-modal .modal-field input:focus { outline: none; border-color: #007bff; }
        #name-modal #start-game-btn { width: 100%; margin-top: 8px; padding: 12px; border: none; border-radius: 8px; background: #2f3542; color: #fff; font-weight: bold; font-size: 15px; cursor: pointer; }
        #name-modal #start-game-btn:hover { background: #1e2229; }
        #name-modal-warning { font-size: 13px; color: #c0392b; margin-top: 10px; min-height: 1.2em; text-align: center; }
        #result-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.55);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 3000;
            padding: 20px;
            box-sizing: border-box;
        }
        #result-modal {
            background: #fff;
            border-radius: 16px;
            padding: 28px 32px;
            max-width: 420px;
            width: 100%;
            box-shadow: 0 16px 48px rgba(0,0,0,0.22);
        }
        #result-modal h2 { margin: 0 0 12px; font-size: 1.4rem; text-align: center; }
        .result-winner-line { font-size: 1.15rem; font-weight: bold; text-align: center; margin: 0 0 20px; color: #2f3542; }
        .result-stats-grid { display: flex; flex-direction: column; gap: 16px; margin-bottom: 22px; }
        .player-card {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 12px 16px;
        }
        .player1-card {
            border-left: 6px solid #ff4d6d;
            box-shadow: 0 1px 8px rgba(255, 77, 109, 0.12);
        }
        .player2-card {
            border-left: 6px solid #4a90e2;
            box-shadow: 0 1px 8px rgba(74, 144, 226, 0.12);
        }
        .player-card h3 { margin: 0 0 8px; font-size: 0.95rem; font-weight: bold; }
        .player1-card h3 { color: #ff4757; }
        .player2-card h3 { color: #2e86de; }
        .player-card ul { margin: 0; padding-left: 18px; color: #444; font-size: 0.9rem; line-height: 1.6; }
        .result-acc { list-style: none; margin-left: -18px; padding-left: 0; color: #666; font-size: 0.85rem; margin-top: 4px; }
        #result-restart-btn { width: 100%; padding: 12px; border: none; border-radius: 8px; background: #2f3542; color: #fff; font-weight: bold; font-size: 15px; cursor: pointer; }
        #result-restart-btn:hover { background: #1e2229; }
        #admin-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.8);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 4000;
            padding: 20px;
            box-sizing: border-box;
        }
        #admin-panel {
            background: #fff;
            border-radius: 14px;
            padding: 24px 28px;
            max-width: 360px;
            width: 100%;
            box-shadow: 0 12px 40px rgba(0,0,0,0.35);
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        #admin-panel button {
            display: block;
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid #d1d8e0;
            background: #f8f9fa;
            font-family: inherit;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
        }
        #admin-panel button:hover { background: #eef2f7; }
        #admin-panel #toggle-answer-test-btn.is-on {
            background: #e8f5e9;
            border-color: #43a047;
            color: #1b5e20;
        }
        #admin-panel #toggle-answer-test-btn.is-on:hover {
            background: #c8e6c9;
            border-color: #2e7d32;
        }
        #wrong-book-btn {
            position: fixed;
            right: 15px;
            top: 52px;
            z-index: 1000;
            padding: 8px 14px;
            border-radius: 8px;
            border: 1px solid #d1d8e0;
            background: #fff;
            color: #333;
            font-size: 13px;
            font-family: inherit;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,0.12);
            transition: background 0.2s, transform 0.2s, box-shadow 0.2s, border-color 0.2s;
            max-width: calc(100vw - 30px);
        }
        #wrong-book-btn:hover {
            background: #eef2f7;
            transform: scale(1.05);
            box-shadow: 0 3px 12px rgba(0,0,0,0.15);
        }
        #wrong-book-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.8);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 3500;
            padding: 20px;
            box-sizing: border-box;
        }
        #wrong-book-panel {
            background: #fff;
            border-radius: 16px;
            padding: 20px;
            width: min(900px, 92vw);
            max-height: 85vh;
            overflow: auto;
            box-shadow: 0 12px 40px rgba(0,0,0,0.35);
        }
        #wrong-book-panel h2 { margin: 0 0 16px; font-size: 1.25rem; text-align: center; }
        #wrong-book-list { margin-bottom: 16px; }
        .wrong-book-section {
            margin-bottom: 22px;
        }
        .wrong-book-section:last-child {
            margin-bottom: 0;
        }
        .wrong-book-section-title {
            font-size: 1.05rem;
            font-weight: bold;
            color: #2f3542;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 2px solid #e0e6ed;
            text-align: left;
        }
        .wrong-book-count {
            font-weight: normal;
            color: #666;
            font-size: 0.9rem;
            margin-left: 6px;
        }
        .wrong-book-item {
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 14px;
            margin-bottom: 14px;
            text-align: left;
        }
        .wrong-book-section-items .wrong-book-item:last-child { margin-bottom: 0; }
        .wrong-book-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: baseline;
            margin-bottom: 10px;
            font-size: 0.95rem;
        }
        .wrong-book-item .wrong-book-meta strong { margin-right: 6px; }
        .wrong-book-question { margin-bottom: 10px; }
        .wrong-book-options { margin-bottom: 10px; }
        .wrong-book-options ol { margin: 6px 0 0; padding-left: 1.4em; }
        .wrong-book-answer { font-size: 0.95rem; }
        .wrong-book-footer-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }
        .wrong-book-footer-actions button {
            flex: 1;
            min-width: 120px;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid #d1d8e0;
            background: #f8f9fa;
            font-family: inherit;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
        }
        .wrong-book-footer-actions button:hover { background: #eef2f7; }
        #wrong-book-clear-all {
            border-color: #e8b4b4;
            background: #fff5f5;
            color: #a61e1e;
        }
        #wrong-book-clear-all:hover {
            background: #ffe8e8;
            border-color: #d64545;
        }
    </style>
</head>
<body>

    <button type="button" id="change-names-btn">Change Names</button>
    <button type="button" id="wrong-book-btn">Wrong Question Notebook</button>

    <div id="wrong-book-overlay" role="dialog" aria-modal="true" aria-labelledby="wrong-book-title" aria-hidden="true">
        <div id="wrong-book-panel">
            <h2 id="wrong-book-title">Wrong Question Notebook</h2>
            <div id="wrong-book-list"></div>
            <div class="wrong-book-footer-actions">
                <button type="button" id="wrong-book-clear-all">Clean all</button>
                <button type="button" id="wrong-book-close">Close</button>
            </div>
        </div>
    </div>

    <div id="name-modal" role="dialog" aria-modal="true" aria-labelledby="name-modal-title">
        <div class="modal-box">
            <h2 id="name-modal-title">输入玩家名称</h2>
            <div class="modal-field">
                <label for="red-name-input">玩家 1（红）</label>
                <input id="red-name-input" type="text" maxlength="40" autocomplete="off" placeholder="例如：Alice">
            </div>
            <div class="modal-field">
                <label for="blue-name-input">玩家 2（蓝）</label>
                <input id="blue-name-input" type="text" maxlength="40" autocomplete="off" placeholder="例如：Bob">
            </div>
            <div id="name-modal-warning"></div>
            <button type="button" id="start-game-btn">Start Game</button>
        </div>
    </div>

    <div id="result-overlay" role="dialog" aria-modal="true" aria-labelledby="result-title" aria-hidden="true">
        <div id="result-modal">
            <h2 id="result-title">游戏结算</h2>
            <p id="winner-name" class="result-winner-line"></p>
            <div class="result-stats-grid">
                <div class="player-card player1-card">
                    <h3 id="result-p1-name"></h3>
                    <ul>
                        <li>作答：<span id="p1-answered">0</span></li>
                        <li>错误：<span id="p1-wrong">0</span></li>
                        <li id="p1-acc-line" class="result-acc">正确率：—</li>
                    </ul>
                </div>
                <div class="player-card player2-card">
                    <h3 id="result-p2-name"></h3>
                    <ul>
                        <li>作答：<span id="p2-answered">0</span></li>
                        <li>错误：<span id="p2-wrong">0</span></li>
                        <li id="p2-acc-line" class="result-acc">正确率：—</li>
                    </ul>
                </div>
            </div>
            <button type="button" id="result-restart-btn">重新开始游戏</button>
        </div>
    </div>

    <div id="admin-overlay" role="dialog" aria-modal="true" aria-label="Admin" aria-hidden="true">
        <div id="admin-panel">
            <button type="button" id="test-random-winner-btn">Test Random Winner</button>
            <button type="button" id="toggle-answer-test-btn">All Answers Correct: OFF</button>
            <button type="button" id="toggle-move-hints-btn">Hints: ON</button>

            <button type="button" id="admin-close">Close</button>
        </div>
    </div>

    <h1>🧪 AS Organic Jump</h1>
    <p style="color: #666;">注意：错误选项现在包含极其相似的试剂和条件！</p>

    <div id="game-layout">
        <div id="board-container"></div>
        <div id="info-panel">
            <div id="info-panel-header">
                <div id="turn-display" style="font-size: 18px; font-weight: bold;">
                    当前回合: <span id="player-label" style="color:#ff4757">—</span>
                </div>

            </div>
            <div id="question-area">
                <div id="question-box">
                    <div id="q-text">点击棋子开始移动...</div>
                    <div id="question-timer-wrap" class="hidden">
                        <div id="question-timer-text">30s</div>
                        <div id="question-timer-bar-outer">
                            <div id="question-timer-bar"></div>
                        </div>
                    </div>
                    <div id="options"></div>
                </div>
            </div>
            <div id="msg" class="status-msg"></div>
            <div class="controls">
                <button id="end-turn-btn" class="btn-action">停止连跳 / 结束回合</button>
                <button type="button" id="restart-btn" class="btn-action">重新开始游戏</button>
            </div>
        </div>
    </div>

<script>
// --- 高迷惑性题库 ---
// 每一题都手动设置了与其高度相似的干扰项 (Distractors)
const deepQuestions = [];

const WRONG_BOOK_KEY = 'organic-jump-wrong-book';
const WRONG_BOOK_SESSION_KEY = 'organic-jump-wrong-book-session';

if (!sessionStorage.getItem(WRONG_BOOK_SESSION_KEY)) {
    try {
        localStorage.removeItem(WRONG_BOOK_KEY);
    } catch (e) {}
    sessionStorage.setItem(WRONG_BOOK_SESSION_KEY, '1');
}

function getWrongBook() {
    try {
        return JSON.parse(localStorage.getItem(WRONG_BOOK_KEY) || '[]');
    } catch {
        return [];
    }
}

function saveWrongBook(records) {
    try {
        localStorage.setItem(WRONG_BOOK_KEY, JSON.stringify(records));
    } catch (e) {}
}

function addWrongQuestionRecord(playerSide) {
    if (!currentQuestionItem || !Array.isArray(currentQuestionChoices) || !currentQuestionChoices.length) return;

    const playerNameSnapshot = playerSide === 'red' ? String(player1Name || '') : String(player2Name || '');

    const records = getWrongBook();
    records.push({
        player: playerNameSnapshot,
        side: playerSide,
        question: currentQuestionItem.q,
        choices: [...currentQuestionChoices],
        answer: currentQuestionItem.a,
        timestamp: Date.now()
    });
    saveWrongBook(records);
}

function escapeHtml(str) {
    return String(str)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
}

function renderWrongBook() {
    const container = document.getElementById('wrong-book-list');
    const records = getWrongBook();

    if (!records.length) {
        container.innerHTML = '<p>No wrong questions yet.</p>';
        return;
    }

    const byPlayer = new Map();
    for (const item of records) {
        const key = item.player != null ? String(item.player) : '';
        if (!byPlayer.has(key)) byPlayer.set(key, []);
        byPlayer.get(key).push(item);
    }

    const names = [...byPlayer.keys()].sort((a, b) => {
        if (a === '' && b !== '') return 1;
        if (b === '' && a !== '') return -1;
        return a.localeCompare(b, 'zh-CN');
    });

    for (const name of names) {
        const list = byPlayer.get(name);
        list.sort((a, b) => (a.timestamp || 0) - (b.timestamp || 0));
    }

    function renderItem(item, indexInGroup) {
        return `
      <div class="wrong-book-item">
        <div class="wrong-book-meta">
          <strong>#${indexInGroup + 1}</strong>
        </div>
        <div class="wrong-book-question"><strong>Question:</strong> ${escapeHtml(item.question)}</div>
        <div class="wrong-book-options">
          <strong>Options:</strong>
          <ol>
            ${item.choices.map(choice => `<li>${escapeHtml(choice)}</li>`).join('')}
          </ol>
        </div>
        <div class="wrong-book-answer"><strong>Correct Answer:</strong> ${escapeHtml(item.answer)}</div>
      </div>
    `;
    }

    container.innerHTML = names.map((name) => {
        const list = byPlayer.get(name);
        const displayName = name === '' ? '（未命名）' : name;
        const itemsHtml = list.map((item, i) => renderItem(item, i)).join('');
        return `
      <section class="wrong-book-section">
        <div class="wrong-book-section-title">${escapeHtml(displayName)}<span class="wrong-book-count">共 ${list.length} 题</span></div>
        <div class="wrong-book-section-items">${itemsHtml}</div>
      </section>
    `;
    }).join('');
}

function openWrongBook() {
    renderWrongBook();
    const o = document.getElementById('wrong-book-overlay');
    o.style.display = 'flex';
    o.setAttribute('aria-hidden', 'false');
}

function closeWrongBook() {
    const o = document.getElementById('wrong-book-overlay');
    o.style.display = 'none';
    o.setAttribute('aria-hidden', 'true');
}

function clearAllWrongBook() {
    if (!window.confirm('确定要清空错题本中的全部记录吗？\n此操作无法撤销。')) return;
    saveWrongBook([]);
    renderWrongBook();
}

let testAllAnswersCorrect = (function () {
    try {
        return localStorage.getItem('allAnswersCorrectMode') === 'true';
    } catch (e) {
        return false;
    }
})();

let showMoveHints = localStorage.getItem('showMoveHints');
showMoveHints = showMoveHints === null ? true : showMoveHints === 'true';

const layout = [4, 5, 6, 7, 6, 5, 4];
const LAYOUT_MAX_W = Math.max(...layout);
const HEX_STEP_Y = Math.sqrt(3) / 2;

function getRowOffset(r) {
    return (LAYOUT_MAX_W - layout[r]) / 2;
}

function getSlotCenter(r, c) {
    return {
        x: getRowOffset(r) + c + 0.5,
        y: r * HEX_STEP_Y
    };
}

function isValidCoord(r, c) {
    return r >= 0 && r < layout.length && c >= 0 && c < layout[r];
}

function getSlot(r, c) {
    if (!isValidCoord(r, c)) return null;
    return document.querySelector(`.slot[data-r="${r}"][data-c="${c}"]`);
}

function slotHasPiece(slot) {
    return !!(slot && slot.querySelector('.piece'));
}

function isSlotEmpty(slot) {
    return !!(slot && !slot.querySelector('.piece'));
}

function sameSlot(a, b) {
    return !!(a && b && a.dataset.r === b.dataset.r && a.dataset.c === b.dataset.c);
}

function getNeighborCoords(r, c) {
    const p = getSlotCenter(r, c);
    const out = [];
    for (let r2 = 0; r2 < layout.length; r2++) {
        for (let c2 = 0; c2 < layout[r2]; c2++) {
            if (r2 === r && c2 === c) continue;
            const p2 = getSlotCenter(r2, c2);
            const d = Math.hypot(p2.x - p.x, p2.y - p.y);
            if (d > 0.9 && d < 1.1) out.push([r2, c2]);
        }
    }
    return out;
}

function findClosestSlotToPoint(px, py) {
    let best = null;
    let bestD = Infinity;
    for (let r = 0; r < layout.length; r++) {
        for (let c = 0; c < layout[r]; c++) {
            const p = getSlotCenter(r, c);
            const d = Math.hypot(p.x - px, p.y - py);
            if (d < bestD) {
                bestD = d;
                best = { r, c };
            }
        }
    }
    return bestD < 0.2 ? best : null;
}

function getAdjacentSlots(slot) {
    const r = +slot.dataset.r;
    const c = +slot.dataset.c;
    return getNeighborCoords(r, c).map(([nr, nc]) => getSlot(nr, nc)).filter(Boolean);
}

function getJumpTargets(r, c) {
    const fromPt = getSlotCenter(r, c);
    const seen = new Set();
    const out = [];
    getNeighborCoords(r, c).forEach(([mr, mc]) => {
        const mid = getSlot(mr, mc);
        if (!slotHasPiece(mid)) return;
        const midPt = getSlotCenter(mr, mc);
        const landingX = 2 * midPt.x - fromPt.x;
        const landingY = 2 * midPt.y - fromPt.y;
        const landCoord = findClosestSlotToPoint(landingX, landingY);
        if (!landCoord) return;
        if (landCoord.r === r && landCoord.c === c) return;
        if (landCoord.r === mr && landCoord.c === mc) return;
        const land = getSlot(landCoord.r, landCoord.c);
        if (!land || !isSlotEmpty(land)) return;
        const key = landCoord.r + ',' + landCoord.c;
        if (seen.has(key)) return;
        seen.add(key);
        out.push(land);
    });
    return out;
}

function getMoveType(from, to) {
    const r = +from.dataset.r;
    const c = +from.dataset.c;

    const neighbors = getNeighborCoords(r, c);
    if (neighbors.some(([nr, nc]) =>
        nr === +to.dataset.r && nc === +to.dataset.c
    )) {
        return 'walk';
    }

    const jumps = getJumpTargets(r, c);
    if (jumps.some(s => sameSlot(s, to))) {
        return 'jump';
    }

    return null;
}

function clearMoveHighlights() {
    document.querySelectorAll('.slot').forEach(s => {
        s.classList.remove('jump-debug', 'walk-debug', 'pending-target');
    });
}

function refreshBoardHighlights() {
    clearMoveHighlights();
    if (!showMoveHints || gameOver) return;
    if (selectedSlot) {
        const r = +selectedSlot.dataset.r;
        const c = +selectedSlot.dataset.c;
        if (!isMoving) {
            getNeighborCoords(r, c).forEach(([nr, nc]) => {
                const s = getSlot(nr, nc);
                if (s && isSlotEmpty(s)) s.classList.add('walk-debug');
            });
        }
        getJumpTargets(r, c).forEach(s => s.classList.add('jump-debug'));
    }
    if (pendingMoveTarget && isAwaitingAnswer) {
        pendingMoveTarget.classList.add('pending-target');
    }
}

let currentPlayer = 1;
let selectedSlot = null;
let hasAnswered = false;
let isMoving = false;
let gameOver = false;
let turnLocked = false;
let player1Name = '';
let player2Name = '';
let player1Answered = 0;
let player1Wrong = 0;
let player2Answered = 0;
let player2Wrong = 0;
let pendingMoveFrom = null;
let pendingMoveTarget = null;
let pendingMoveType = null;
let currentQuestionItem = null;
let currentQuestionChoices = [];
let isAwaitingAnswer = false;
let questionTimerId = null;
let questionTimeLeft = 30;
let questionDeadline = null;
const QUESTION_TIME_LIMIT = 30;
const RECENT_QUESTION_WINDOW = 5;
let recentQuestionIndices = [];

function pickRandomQuestionIndex() {
    const n = deepQuestions.length;
    const banned = new Set(recentQuestionIndices);
    const candidates = [];
    for (let i = 0; i < n; i++) {
        if (!banned.has(i)) candidates.push(i);
    }
    const pool = candidates.length > 0 ? candidates : Array.from({ length: n }, (_, i) => i);
    return pool[Math.floor(Math.random() * pool.length)];
}
function clearAllSelectedHighlights() {
    document.querySelectorAll('.slot.selected').forEach(s => {
        s.classList.remove('selected');
    });
}

function clearSelectedPiece() {
    clearAllSelectedHighlights();
    selectedSlot = null;
}

function stopQuestionTimer() {
    if (questionTimerId !== null) {
        clearInterval(questionTimerId);
        questionTimerId = null;
    }
    questionDeadline = null;
}

function showQuestionTimer() {
    document.getElementById('question-timer-wrap').classList.remove('hidden');
}

function hideQuestionTimer() {
    document.getElementById('question-timer-wrap').classList.add('hidden');
    const bar = document.getElementById('question-timer-bar');
    bar.style.width = '100%';
    bar.style.background = 'hsl(120, 85%, 50%)';
    document.getElementById('question-timer-text').textContent = QUESTION_TIME_LIMIT + 's';
}

function updateQuestionTimerUI(remainingMs, ratio) {
    const sec = Math.max(0, Math.ceil(remainingMs / 1000));
    document.getElementById('question-timer-text').textContent = sec + 's';
    const bar = document.getElementById('question-timer-bar');
    const r = Math.max(0, Math.min(1, ratio));
    bar.style.width = `${r * 100}%`;
    const hue = r * 120;
    bar.style.background = `hsl(${hue}, 85%, 50%)`;
}



function startQuestionTimer() {
    stopQuestionTimer();
    questionDeadline = Date.now() + QUESTION_TIME_LIMIT * 1000;
    showQuestionTimer();
    const tick = () => {
        if (gameOver || !isAwaitingAnswer) {
            stopQuestionTimer();
            return;
        }
        const now = Date.now();
        const remainingMs = Math.max(0, questionDeadline - now);
        const ratio = remainingMs / (QUESTION_TIME_LIMIT * 1000);
        questionTimeLeft = remainingMs / 1000;
        updateQuestionTimerUI(remainingMs, ratio);
        if (remainingMs <= 0) {
            stopQuestionTimer();
            onQuestionTimeout();
        }
    };
    tick();
    questionTimerId = setInterval(tick, 100);
}

function onQuestionTimeout() {
    if (gameOver || !isAwaitingAnswer || currentQuestionItem === null) return;
    recordAnswer(false);
    handleQuestionWrong('timeout');
}

function handleQuestionWrong(reason) {
    turnLocked = true;
    stopQuestionTimer();
    hideQuestionTimer();
    const ans = currentQuestionItem ? currentQuestionItem.a : '';
    addWrongQuestionRecord(currentPlayer === 1 ? 'red' : 'blue');
    clearSelectedPiece();
    clearPendingQuestionState();
    if (reason === 'timeout') {
        showMsg('⏰ 时间到，判定错误。', 'incorrect');
    } else {
        showMsg(`❌ 错误！正确答案是: ${ans}`, 'incorrect');
    }
    setTimeout(endTurn, 2500);
}

function clearPendingQuestionState() {
    stopQuestionTimer();
    hideQuestionTimer();
    pendingMoveFrom = null;
    pendingMoveTarget = null;
    pendingMoveType = null;
    currentQuestionItem = null;
    currentQuestionChoices = [];
    isAwaitingAnswer = false;
    refreshBoardHighlights();
}

function ensureQuestionLocked() {
    if (turnLocked || gameOver) return;
    if (currentQuestionItem === null) {
        const idx = pickRandomQuestionIndex();
        currentQuestionItem = deepQuestions[idx];
        recentQuestionIndices.push(idx);
        if (recentQuestionIndices.length > RECENT_QUESTION_WINDOW) {
            recentQuestionIndices.shift();
        }
        currentQuestionChoices = [currentQuestionItem.a, ...currentQuestionItem.d].sort(() => 0.5 - Math.random());
        isAwaitingAnswer = true;
        startQuestionTimer();
    }
}

function renderCurrentQuestion() {
    const item = currentQuestionItem;
    if (!item) return;
    document.getElementById('q-text').innerHTML = `<b>起跳验证：</b><br>${item.q}`;
    const opt = document.getElementById('options');
    opt.innerHTML = '';
    currentQuestionChoices.forEach(optText => {
        const btn = document.createElement('button');
        btn.className = 'option-btn';
        btn.textContent = optText;
        btn.onclick = () => {
            if (turnLocked || gameOver) return;
            stopQuestionTimer();
            hideQuestionTimer();
            const qItem = currentQuestionItem;
            const correct = testAllAnswersCorrect ? true : (optText === qItem.a);
            recordAnswer(correct);
            if (correct) {
                const from = pendingMoveFrom;
                const to = pendingMoveTarget;
                const mt = pendingMoveType;
                if (!from || !to || mt == null) return;
                hasAnswered = true;
                clearPendingQuestionState();
                showMsg("✅ 正确！移动授权成功。", "correct");
                execute(from, to, mt);
            } else {
                handleQuestionWrong('wrong');
            }
        };
        opt.appendChild(btn);
    });
}

function resetStats() {
    player1Answered = 0;
    player1Wrong = 0;
    player2Answered = 0;
    player2Wrong = 0;
}

function recordAnswer(isCorrect) {
    if (currentPlayer === 1) {
        player1Answered++;
        if (!isCorrect) player1Wrong++;
    } else {
        player2Answered++;
        if (!isCorrect) player2Wrong++;
    }
}

function getPlayerName(playerNum) {
    return playerNum === 1 ? player1Name : player2Name;
}

function updateTurnDisplay() {
    const label = document.getElementById('player-label');
    label.textContent = getPlayerName(currentPlayer) + ' 的回合';
    label.style.color = currentPlayer === 1 ? '#ff4757' : '#2e86de';
}

function winnerDisplayName(playerNum) {
    const n = (playerNum === 1 ? player1Name : player2Name).trim();
    return n || (playerNum === 1 ? '玩家 1' : '玩家 2');
}

/** 棋盘共 7 行 (0–6)，中间行为 index 3。胜利：己方全部棋子到达中线或对方半场（含踩在中线 r===3）。 */
const BOARD_MIDDLE_ROW = 3;

function checkWin() {
    const p1Pieces = document.querySelectorAll('.piece.p1');
    const p2Pieces = document.querySelectorAll('.piece.p2');
    const p1AllPast = p1Pieces.length && [...p1Pieces].every((p) => {
        const slot = p.closest('.slot');
        return slot && +slot.dataset.r >= BOARD_MIDDLE_ROW;
    });
    const p2AllPast = p2Pieces.length && [...p2Pieces].every((p) => {
        const slot = p.closest('.slot');
        return slot && +slot.dataset.r <= BOARD_MIDDLE_ROW;
    });
    if (p1AllPast) return 1;
    if (p2AllPast) return 2;
    return null;
}

function showResultModal(winnerNum) {
    const wname = winnerDisplayName(winnerNum);
    document.getElementById('winner-name').textContent = '胜利者：' + wname;
    document.getElementById('result-p1-name').textContent = '玩家 1 / ' + winnerDisplayName(1);
    document.getElementById('result-p2-name').textContent = '玩家 2 / ' + winnerDisplayName(2);
    document.getElementById('p1-answered').textContent = player1Answered;
    document.getElementById('p1-wrong').textContent = player1Wrong;
    document.getElementById('p2-answered').textContent = player2Answered;
    document.getElementById('p2-wrong').textContent = player2Wrong;
    const correct1 = player1Answered - player1Wrong;
    const correct2 = player2Answered - player2Wrong;
    const acc1 = player1Answered > 0 ? Math.round((correct1 / player1Answered) * 100) + '%' : '—';
    const acc2 = player2Answered > 0 ? Math.round((correct2 / player2Answered) * 100) + '%' : '—';
    document.getElementById('p1-acc-line').textContent = '正确率：' + acc1;
    document.getElementById('p2-acc-line').textContent = '正确率：' + acc2;
    const ro = document.getElementById('result-overlay');
    ro.style.display = 'flex';
    ro.setAttribute('aria-hidden', 'false');
}

function hideResultOverlay() {
    const ro = document.getElementById('result-overlay');
    ro.style.display = 'none';
    ro.setAttribute('aria-hidden', 'true');
}

function declareWinner(playerNum) {
    gameOver = true;
    turnLocked = false;
    clearAllSelectedHighlights();
    selectedSlot = null;
    hasAnswered = false;
    isMoving = false;
    clearPendingQuestionState();
    document.getElementById('end-turn-btn').style.display = 'none';
    document.getElementById('options').innerHTML = '';
    const name = winnerDisplayName(playerNum);
    document.getElementById('player-label').textContent = '游戏结束：' + name + ' 获胜！';
    document.getElementById('player-label').style.color = playerNum === 1 ? '#ff4757' : '#2e86de';
    document.getElementById('q-text').textContent = '游戏已结束。';
    document.getElementById('msg').style.display = 'none';
    showResultModal(playerNum);
}

// TEST ONLY: force random winner for UI/debugging
function forceRandomWinner() {
    if (gameOver) return;
    const randomPlayer = Math.random() < 0.5 ? 1 : 2;
    declareWinner(randomPlayer);
}

function loadSavedPlayerNames() {
    try {
        const s1 = localStorage.getItem('player1Name');
        const s2 = localStorage.getItem('player2Name');
        const n1 = s1 != null ? String(s1).trim() : '';
        const n2 = s2 != null ? String(s2).trim() : '';
        if (n1 && n2) {
            player1Name = n1;
            player2Name = n2;
            return true;
        }
    } catch (e) {}
    return false;
}

function prefillModalInputs() {
    try {
        const s1 = localStorage.getItem('player1Name');
        const s2 = localStorage.getItem('player2Name');
        const el1 = document.getElementById('red-name-input');
        const el2 = document.getElementById('blue-name-input');
        if (s1 != null && s1 !== '') el1.value = String(s1).trim();
        if (s2 != null && s2 !== '') el2.value = String(s2).trim();
    } catch (e) {}
}

function openNameModal(prefill) {
    document.getElementById('name-modal-warning').textContent = '';
    document.getElementById('name-modal').style.display = 'flex';
    const el1 = document.getElementById('red-name-input');
    const el2 = document.getElementById('blue-name-input');
    if (prefill) {
        el1.value = player1Name || '';
        el2.value = player2Name || '';
    } else {
        el1.value = '';
        el2.value = '';
        prefillModalInputs();
    }
}

function nameInputTriggersAdmin(trimmed) {
    return trimmed === '/' || (trimmed.length > 1 && trimmed.endsWith('/'));
}

function confirmNameModal() {
    const w = document.getElementById('name-modal-warning');
    const redIn = document.getElementById('red-name-input');
    const blueIn = document.getElementById('blue-name-input');
    const n1 = redIn.value.trim();
    const n2 = blueIn.value.trim();
    if (nameInputTriggersAdmin(n1) || nameInputTriggersAdmin(n2)) {
        w.textContent = '';
        openAdminPanel();
        return;
    }
    if (!n1 || !n2) {
        w.textContent = '请填写双方名称后再开始。';
        return;
    }
    w.textContent = '';
    player1Name = n1;
    player2Name = n2;
    try {
        localStorage.setItem('player1Name', n1);
        localStorage.setItem('player2Name', n2);
    } catch (e) {}
    document.getElementById('name-modal').style.display = 'none';
    restartGame();
}

function restartGame() {
    hideResultOverlay();
    resetStats();
    recentQuestionIndices = [];
    turnLocked = false;
    clearAllSelectedHighlights();
    selectedSlot = null;
    hasAnswered = false;
    isMoving = false;
    clearPendingQuestionState();
    gameOver = false;
    currentPlayer = 1;
    document.getElementById('end-turn-btn').style.display = 'none';
    document.getElementById('msg').style.display = 'none';
    document.getElementById('q-text').textContent = '点击棋子开始移动...';
    document.getElementById('options').innerHTML = '';
    initBoard();
    updateTurnDisplay();
    refreshBoardHighlights();
}

function initBoard() {
    const container = document.getElementById('board-container');
    container.innerHTML = '';
    layout.forEach((cols, r) => {
        const rowDiv = document.createElement('div');
        rowDiv.className = 'row';
        for (let c = 0; c < cols; c++) {
            const slot = document.createElement('div');
            slot.className = 'slot';
            slot.dataset.r = r; slot.dataset.c = c;
            if (r <= 1) slot.innerHTML = `<div class="piece p1"></div>`;
            if (r >= 5) slot.innerHTML = `<div class="piece p2"></div>`;
            slot.onclick = () => handleClick(slot);
            rowDiv.appendChild(slot);
        }
        container.appendChild(rowDiv);
    });
}

function handleClick(slot) {
    if (turnLocked || gameOver) return;
    const piece = slot.querySelector('.piece');
    if (isMoving) {
        if (!piece) tryJump(selectedSlot, slot);
        return;
    }
    if (piece && piece.classList.contains('p' + currentPlayer)) {
        const prevSelected = selectedSlot;
        clearAllSelectedHighlights();
        selectedSlot = slot;
        slot.classList.add('selected');
        if (isAwaitingAnswer && prevSelected && prevSelected !== slot) {
            pendingMoveFrom = null;
            pendingMoveTarget = null;
            pendingMoveType = null;
        }
        refreshBoardHighlights();
        return;
    }
    if (selectedSlot && !piece) {
        console.log('--- DEBUG CLICK ---');
        console.log('FROM:', selectedSlot.dataset.r, selectedSlot.dataset.c);
        console.log('TO:', slot.dataset.r, slot.dataset.c);
        const move = getMoveType(selectedSlot, slot);
        console.log('MOVE TYPE:', move);
        const jumps = getJumpTargets(+selectedSlot.dataset.r, +selectedSlot.dataset.c);
        console.log('VALID JUMPS:', jumps.map(s => [s.dataset.r, s.dataset.c]));
        if (move === null) console.warn('INVALID MOVE');
        if (move) {
            if (!hasAnswered) {
                pendingMoveFrom = selectedSlot;
                pendingMoveTarget = slot;
                pendingMoveType = move;
                ensureQuestionLocked();
                renderCurrentQuestion();
                refreshBoardHighlights();
            } else {
                execute(selectedSlot, slot, move);
            }
        }
    }
}

function execute(from, to, type) {
    to.innerHTML = from.innerHTML;
    from.innerHTML = '';
    clearAllSelectedHighlights();
    selectedSlot = null;
    const winner = checkWin();
    if (winner) {
        declareWinner(winner);
        return;
    }
    if (type === 'walk') {
        endTurn();
    } else {
        isMoving = true;
        selectedSlot = to;
        selectedSlot.classList.add('selected');
        document.getElementById('end-turn-btn').style.display = 'block';
        document.getElementById('q-text').textContent = "连跳模式开启！点击落点或结束。";
        document.getElementById('options').innerHTML = '';
        refreshBoardHighlights();
    }
}

function tryJump(from, to) {
    if (turnLocked || gameOver) return;
    console.log('--- DEBUG CLICK (chain jump) ---');
    console.log('FROM:', from.dataset.r, from.dataset.c);
    console.log('TO:', to.dataset.r, to.dataset.c);
    const moveType = getMoveType(from, to);
    console.log('MOVE TYPE:', moveType);
    const jumps = getJumpTargets(+from.dataset.r, +from.dataset.c);
    console.log('VALID JUMPS:', jumps.map(s => [s.dataset.r, s.dataset.c]));
    if (moveType === null) console.warn('INVALID MOVE');
    if (moveType === 'jump') execute(from, to, 'jump');
}

function endTurn() {
    if (gameOver) return;
    turnLocked = false;
    clearAllSelectedHighlights();
    selectedSlot = null;
    hasAnswered = false;
    isMoving = false;
    clearPendingQuestionState();
    currentPlayer = currentPlayer === 1 ? 2 : 1;
    updateTurnDisplay();
    document.getElementById('end-turn-btn').style.display = 'none';
    document.getElementById('q-text').textContent = "请选中棋子...";
    document.getElementById('options').innerHTML = '';
    document.getElementById('msg').style.display = 'none';
}

function showMsg(t, c) {
    const m = document.getElementById('msg');
    m.textContent = t; m.className = 'status-msg ' + c; m.style.display = 'block';
}

document.getElementById('end-turn-btn').onclick = endTurn;
document.getElementById('restart-btn').onclick = restartGame;
document.getElementById('result-restart-btn').onclick = restartGame;
document.getElementById('change-names-btn').onclick = function () { openNameModal(true); };
document.getElementById('wrong-book-btn').onclick = openWrongBook;
document.getElementById('wrong-book-clear-all').onclick = clearAllWrongBook;
document.getElementById('wrong-book-close').onclick = closeWrongBook;
document.getElementById('wrong-book-panel').addEventListener('click', function (e) {
    e.stopPropagation();
});
document.getElementById('wrong-book-overlay').addEventListener('click', function () {
    closeWrongBook();
});
document.getElementById('test-random-winner-btn').onclick = forceRandomWinner;

function updateAnswerTestToggleButton() {
    const btn = document.getElementById('toggle-answer-test-btn');
    btn.textContent = testAllAnswersCorrect ? 'All Answers Correct: ON' : 'All Answers Correct: OFF';
    btn.classList.toggle('is-on', testAllAnswersCorrect);
}
document.getElementById('toggle-answer-test-btn').onclick = function () {
    testAllAnswersCorrect = !testAllAnswersCorrect;
    try {
        localStorage.setItem('allAnswersCorrectMode', String(testAllAnswersCorrect));
    } catch (e) {}
    updateAnswerTestToggleButton();
};
updateAnswerTestToggleButton();

function updateMoveHintsButton() {
    const btn = document.getElementById('toggle-move-hints-btn');
    btn.textContent = showMoveHints ? 'Hints: ON' : 'Hints: OFF';
}
document.getElementById('toggle-move-hints-btn').onclick = function () {
    showMoveHints = !showMoveHints;
    try {
        localStorage.setItem('showMoveHints', String(showMoveHints));
    } catch (e) {}
    updateMoveHintsButton();
    refreshBoardHighlights();
};
updateMoveHintsButton();

document.getElementById('start-game-btn').onclick = confirmNameModal;

function openAdminPanel() {
    const overlay = document.getElementById('admin-overlay');
    overlay.style.display = 'flex';
    overlay.setAttribute('aria-hidden', 'false');
}

function stripTrailingSlashFromNameInputs() {
    ['red-name-input', 'blue-name-input'].forEach(function (id) {
        const el = document.getElementById(id);
        if (!el) return;
        const v = el.value;
        if (v.trim() === '/') {
            el.value = '';
        } else if (v.trim().endsWith('/')) {
            el.value = v.replace(/\s*\/+\s*$/, '');
        }
    });
}

function closeAdminPanel() {
    const overlay = document.getElementById('admin-overlay');
    overlay.style.display = 'none';
    overlay.setAttribute('aria-hidden', 'true');
    stripTrailingSlashFromNameInputs();
}

function setupNameInputAdminTrigger(input) {
    input.addEventListener('keydown', function (e) {
        if (e.key !== 'Enter') return;
        const t = input.value.trim();
        if (!nameInputTriggersAdmin(t)) return;
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();
        openAdminPanel();
    }, true);
}

setupNameInputAdminTrigger(document.getElementById('red-name-input'));
setupNameInputAdminTrigger(document.getElementById('blue-name-input'));

document.getElementById('admin-panel').addEventListener('click', function (e) {
    e.stopPropagation();
});

document.getElementById('admin-overlay').addEventListener('click', function () {
    closeAdminPanel();
});

document.addEventListener('keydown', function (e) {
    if (e.key !== 'Escape') return;
    const wb = document.getElementById('wrong-book-overlay');
    if (wb && wb.style.display === 'flex') {
        closeWrongBook();
        return;
    }
    const overlay = document.getElementById('admin-overlay');
    if (overlay && overlay.style.display === 'flex') closeAdminPanel();
});

document.getElementById('admin-close').onclick = closeAdminPanel;


(function bootGame() {
    if (loadSavedPlayerNames()) {
        document.getElementById('name-modal').style.display = 'none';
        resetStats();
        hideResultOverlay();
        clearPendingQuestionState();
        gameOver = false;
        turnLocked = false;
        currentPlayer = 1;
        clearAllSelectedHighlights();
        selectedSlot = null;
        hasAnswered = false;
        isMoving = false;
        initBoard();
        updateTurnDisplay();
        refreshBoardHighlights();
    } else {
        openNameModal(false);
    }
})();
</script>
</body>
</html>
